# Copy these into Vercel → Project → Settings → Environment Variables
# (and into a local .env if you run `vercel dev`). Do NOT commit real values.

# Supabase → Project Settings → API → Project URL
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Supabase → Project Settings → API → service_role secret (server-side only!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# ---- Email notifications (optional) ----
# Leads are always saved to Supabase. To ALSO get an email per lead, sign up at
# resend.com (free), create an API key, and set these in Vercel. Your recipient
# address stays private here (env var only — never shown on the site).
RESEND_API_KEY=your-resend-api-key
LEAD_NOTIFY_EMAIL=your-private-inbox@example.com
# Optional custom sender (defaults to onboarding@resend.dev, which works without a domain):
# LEAD_FROM_EMAIL=ConnectWorks Leads <leads@yourdomain.com>
